#!/usr/bin/env node
import { spawn } from "node:child_process";
import { dirname, resolve } from "node:path";
import { fileURLToPath } from "node:url";

const rootDir = resolve(dirname(fileURLToPath(import.meta.url)), "..");
const isRecoveryMode = process.env.CLAUDE_CODE_FORCE_RECOVERY_CLI === "1";
const entrypoint = isRecoveryMode
  ? resolve(rootDir, "./src/localRecoveryCli.ts")
  : resolve(rootDir, "./src/entrypoints/cli.tsx");

const bunCommand = process.platform === "win32" ? "bun.exe" : "bun";
const child = spawn(
  bunCommand,
  ["--env-file=.env", entrypoint, ...process.argv.slice(2)],
  {
    cwd: process.cwd(),
    stdio: "inherit",
    shell: false,
  },
);

child.on("error", (error) => {
  console.error(`Failed to start Bun runtime: ${error.message}`);
  process.exit(1);
});

child.on("exit", (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal);
    return;
  }
  process.exit(code ?? 0);
});
